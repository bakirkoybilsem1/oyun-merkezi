{
  "rewrites": [
    { "source": "/ac", "destination": "/ac/index.html" },
    { "source": "/:oyun", "destination": "/:oyun/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
